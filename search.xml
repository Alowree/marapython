      <title>Git Rookies</title>
      <link href="/posts/3239246065/"/>
      <url>/posts/3239246065/</url>
      
        <content type="html"><![CDATA[<h2 id="Basic"><a href="#Basic" class="headerlink" title="Basic"></a>Basic</h2><h3 id="git-init"><a href="#git-init" class="headerlink" title="git init"></a><code>git init</code></h3><h3 id="git-status"><a href="#git-status" class="headerlink" title="git status"></a><code>git status</code></h3><h3 id="git-add"><a href="#git-add" class="headerlink" title="git add"></a><code>git add</code></h3><h3 id="git-commit"><a href="#git-commit" class="headerlink" title="git commit"></a><code>git commit</code></h3><h3 id="git-log"><a href="#git-log" class="headerlink" title="git log"></a><code>git log</code></h3><h3 id="git-diff"><a href="#git-diff" class="headerlink" title="git diff"></a><code>git diff</code></h3><p>工作树与暂存区</p><h3 id="git-diff-HEAD"><a href="#git-diff-HEAD" class="headerlink" title="git diff HEAD"></a><code>git diff HEAD</code></h3><p>工作树与最新提交</p><h2 id="Branches"><a href="#Branches" class="headerlink" title="Branches"></a>Branches</h2><h3 id="git-branch"><a href="#git-branch" class="headerlink" title="git branch"></a><code>git branch</code></h3><h2 id="Changes"><a href="#Changes" class="headerlink" title="Changes"></a>Changes</h2><h2 id="Push-to-remote-repository"><a href="#Push-to-remote-repository" class="headerlink" title="Push to remote repository"></a>Push to remote repository</h2><h2 id="Pull-from-remote-repository"><a href="#Pull-from-remote-repository" class="headerlink" title="Pull from remote repository"></a>Pull from remote repository</h2>]]></content>
      
      
      
    </entry>
    
    
    
